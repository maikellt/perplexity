{
  "manifest_version": 3,
  "name": "YouTube → Perplexity Summarizer",
  "short_name": "YT Summarizer",
  "description": "Adiciona um botão nas páginas do YouTube para resumir vídeos diretamente no Perplexity, via transcrição automática.",
  "version": "1.0.0",
  "author": "Maikel Takata",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube → Perplexity Summarizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
